{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 10
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 10
      }
    ],
    "afterShellExecution": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 5
      }
    ],
    "afterMCPExecution": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/unbound.py",
        "timeout": 60
      }
    ]
  }
}
